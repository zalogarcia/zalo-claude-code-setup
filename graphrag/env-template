# ==============================================================================
# Repo GraphRAG MCP — Minimal Config
# ==============================================================================
# Copy to ~/repo-graphrag-mcp/.env and set your API key

GRAPH_CREATE_PROVIDER=anthropic
GRAPH_ANALYSIS_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key
GRAPH_CREATE_MODEL_NAME=claude-haiku-4-5
GRAPH_ANALYSIS_MODEL_NAME=claude-sonnet-4-6

# Embedding (bge-small works on macOS without segfaults)
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
EMBEDDING_MAX_TOKEN_SIZE=2048

# Search
SEARCH_TOP_K=40
SEARCH_MODE=mix
MAX_TOTAL_TOKENS=30000
