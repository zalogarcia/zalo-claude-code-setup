{
  "enabledPlugins": {},
  "env": {
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1"
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "/Users/zalo/.vibe-island/bin/vibe-island-bridge --source claude",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "command": "/Users/zalo/.vibe-island/bin/vibe-island-bridge --source claude",
            "timeout": 86400,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(cat | jq -r '.tool_input.file_path // empty'); if [ -n \"$FILE\" ] && echo \"$FILE\" | grep -qE '\\.(ts|tsx|js|jsx|css|json|md|html)$'; then prettier --write \"$FILE\" 2>/dev/null; fi",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(cat | jq -r '.tool_input.file_path // empty'); if [ -n \"$FILE\" ] && echo \"$FILE\" | grep -qE '\\.py$'; then which ruff >/dev/null 2>&1 && ruff format \"$FILE\" 2>/dev/null && ruff check --fix \"$FILE\" 2>/dev/null; fi",
            "timeout": 10000
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "/Users/zalo/.vibe-island/bin/vibe-island-bridge --source claude",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "/Users/zalo/.vibe-island/bin/vibe-island-bridge --source claude",
            "type": "command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "/Users/zalo/.vibe-island/bin/vibe-island-bridge --source claude",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "/Users/zalo/.vibe-island/bin/vibe-island-bridge --source claude",
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "/Users/zalo/.vibe-island/bin/vibe-island-bridge --source claude",
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "/Users/zalo/.vibe-island/bin/vibe-island-bridge --source claude",
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "command": "/Users/zalo/.vibe-island/bin/vibe-island-bridge --source claude",
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "command": "/Users/zalo/.vibe-island/bin/vibe-island-bridge --source claude",
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "/Users/zalo/.vibe-island/bin/vibe-island-bridge --source claude",
            "type": "command"
          }
        ]
      }
    ]
  },
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "command": "/Users/zalo/.vibe-island/bin/vibe-island-statusline",
    "type": "command"
  },
  "voiceEnabled": true
}
